# per-machine, rebuilt by setup.sh - never commit
.qmd/
*.sqlite

# local agent state and permissions can contain API keys or machine paths
.claude/settings.local.json
.claude/settings.local.*
.claude/skills/
.claude/launch.json
.codex/local*

# Obsidian local UI state (noisy in diffs)
.obsidian/workspace*.json
.obsidian/cache

# secrets - never, ever
.env
*.env
*.key
*.pem
*.p12
*.pfx
*secret*
*secrets*

# transient API responses / scratch outputs
cala_resp*.json
.cala_tmp/
tmp/
temp/

# app build outputs and dependencies
app/node_modules/
app/dist/
app/dist-electron/
app/.vite/
__pycache__/
*.pyc

# OS junk
.DS_Store
